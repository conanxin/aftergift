# Aftergift Backend MVP - Environment Variables
# Copy this file to .env and fill in values

# Environment mode: development | staging | production
AFTERGIFT_ENV=development

# SQLite database path (relative to backend/ directory or absolute)
AFTERGIFT_DB_PATH=./aftergift_dev.db

# AI Review toggle (Phase 2B: always false, use mock rules)
# Set to true in Phase 2D when real AI API is integrated
AFTERGIFT_ENABLE_REAL_AI_REVIEW=false

# Admin authentication token (dev only, change in production!)
# Phase 2C+ should use proper JWT/OAuth2
# NOTE: This is a development-only example token.
# The actual working token for local dev is: dev-admin-aftergift-001
# Production environments MUST replace with a secure random token.
AFTERGIFT_ADMIN_TOKEN=dev-ad...-001

# -- Phase 2E: JWT Auth ---------------------------------------------------------
# AFTERGIFT_JWT_SECRET: replace with a strong random secret in production.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# DO NOT use the placeholder value below in production!
AFTERGIFT_JWT_SECRET=replac...cret
AFTERGIFT_JWT_ALGORITHM=HS256
AFTERGIFT_ACCESS_TOKEN_TTL_SECONDS=3600

# -- Phase 2E-2: Moderation Provider --------------------------------------------
# AFTERGIFT_MODERATION_PROVIDER: mock | openai | baidu
# Default: mock (no external API needed, safe fallback)
# openai/baidu require AFTERGIFT_ENABLE_REAL_AI_REVIEW=true AND API keys configured
# DO NOT set real API keys in this file -- use .env (not committed to git)
AFTERGIFT_MODERATION_PROVIDER=mock

# OpenAI API Key -- only used when provider=openai AND ENABLE_REAL_AI_REVIEW=true
# OPENAI_API_KEY=   # DO NOT commit real keys to git
OPENAI_API_KEY=

# Baidu Content Review API Key -- only used when provider=baidu
# BAIDU_CONTENT_REVIEW_API_KEY=   # DO NOT commit real keys to git
BAIDU_CONTENT_REVIEW_API_KEY=

# -- Phase 2E-4: OpenAI Moderation Provider -------------------------------------
# OpenAI Moderation API model (default: omni-moderation-latest)
# See: https://platform.openai.com/docs/guides/moderation
AFTERGIFT_OPENAI_MODERATION_MODEL=omni-moderation-latest

# HTTP timeout for OpenAI API calls (seconds)
AFTERGIFT_OPENAI_TIMEOUT_SECONDS=8

# NOTE: Only AFTERGIFT_ENABLE_REAL_AI_REVIEW=true AND OPENAI_API_KEY is set
# will the OpenAI provider make real API calls. Otherwise it falls back to mock.
