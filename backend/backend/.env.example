# Aftergift Backend MVP - Environment Variables
# Copy this file to .env and fill in values

# Environment mode: development | staging | production
AFTERGIFT_ENV=development

# SQLite database path (relative to backend/ directory or absolute)
AFTERGIFT_DB_PATH=./aftergift_dev.db

# AI Review toggle (Phase 2B: always false, use mock rules)
# Set to true in Phase 2D when real AI API is integrated
AFTERGIFT_ENABLE_REAL_AI_REVIEW=false

# Admin authentication token (dev only, change in production!)
# Phase 2C+ should use proper JWT/OAuth2
# NOTE: This is a development-only example token.
# The actual working token for local dev is: dev-admin-aftergift-001
# Production environments MUST replace with a secure random token.
AFTERGIFT_ADMIN_TOKEN=dev-admin-aftergift-001
